{
  "name": "@traibox/worker",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "dist/main.cjs",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "start": "node --enable-source-maps dist/main.cjs",
    "build": "esbuild src/main.ts --bundle --platform=node --format=cjs --target=node22 --alias:@traibox/contracts=../../packages/contracts/src/index.ts --alias:@traibox/db=../../packages/db/src/index.ts --alias:@traibox/profiles=../../packages/profiles/src/index.ts --sourcemap --outfile=dist/main.cjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@traibox/contracts": "workspace:*",
    "@traibox/db": "workspace:*",
    "@traibox/profiles": "workspace:*",
    "dotenv": "^16.4.7",
    "ethers": "^6.13.4",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@types/pg": "^8.20.0",
    "esbuild": "0.28.0",
    "tsx": "^4.19.2"
  }
}
