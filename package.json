{
  "name": "traibox",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "turbo dev",
    "demo": "echo \"Open http://localhost:3000/demo\" && NEXT_PUBLIC_DEMO_MODE=1 turbo dev --filter=@traibox/web",
    "build": "turbo build",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "test:alpha:integration": "pnpm --filter @traibox/api test -- src/services/alpha.scenario.test.ts",
    "test:capital:integration": "pnpm --filter @traibox/api test -- src/services/capital-foundation.scenario.test.ts",
    "test:rails:integration": "pnpm --filter @traibox/api test -- src/services/rails.scenario.test.ts",
    "test:trade-brain": "PYTHONPATH=apps/trade-brain python3 -m unittest discover -s apps/trade-brain/tests",
    "eval:trade-brain": "PYTHONPATH=apps/trade-brain python3 -m app.eval_harness --suite all",
    "eval:trade-brain:ci": "PYTHONPATH=apps/trade-brain python3 -m app.eval_harness --suite all --output artifacts/trade-brain-evals/latest.json",
    "release:gate": "pnpm conformance && pnpm conformance:test && pnpm audit:component-tokens && pnpm lint && pnpm typecheck && pnpm test && pnpm test:trade-brain && pnpm eval:trade-brain:ci && pnpm build",
    "release:gate:ci": "pnpm release:gate && pnpm db:migrate:dry-run && pnpm test:alpha:integration",
    "staging:github:check": "tsx apps/api/src/ops/github-staging-readiness.ts",
    "staging:secrets:check": "tsx apps/api/src/ops/staging-secret-audit.ts",
    "staging:storage:check": "tsx apps/api/src/ops/staging-storage-readiness.ts",
    "staging:rehearsal": "tsx apps/api/src/ops/staging-rehearsal.ts",
    "staging:gonogo:summary": "tsx apps/api/src/ops/staging-gonogo-summary.ts",
    "pilot:check": "tsx packages/profiles/src/check.ts",
    "db:migrate": "tsx packages/db/src/migrate.ts",
    "db:migrate:dry-run": "MIGRATION_DRY_RUN=true tsx packages/db/src/migrate.ts",
    "db:backup:check": "tsx packages/db/src/backup-check.ts",
    "db:reset": "tsx packages/db/src/reset.ts",
    "db:seed": "tsx packages/db/src/seed.ts",
    "conformance": "tsx scripts/conformance/index.mts",
    "conformance:test": "vitest run scripts/conformance --passWithNoTests=false",
    "audit:component-tokens": "tsx scripts/conformance/component-token-audit.mts",
    "audit:component-tokens:update": "tsx scripts/conformance/component-token-audit.mts --write"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@next/eslint-plugin-next": "15.1.6",
    "@types/node": "^22.10.2",
    "eslint": "^9.17.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^5.1.0",
    "globals": "^15.14.0",
    "pnpm": "9.15.4",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "turbo": "^2.3.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.18.0",
    "vitest": "^2.1.8",
    "yaml": "^2.6.1",
    "zod": "^3.24.1"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
