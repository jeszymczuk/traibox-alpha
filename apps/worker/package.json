{
  "name": "@traibox/worker",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "src/main.ts",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "start": "node --import tsx src/main.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@traibox/contracts": "workspace:*",
    "@traibox/db": "workspace:*",
    "@traibox/profiles": "workspace:*",
    "dotenv": "^16.4.7",
    "ethers": "^6.13.4",
    "pg": "^8.20.0",
    "tsx": "^4.19.2"
  },
  "devDependencies": {
    "@types/pg": "^8.20.0"
  }
}
