{
  "name": "traibox",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "turbo dev",
    "demo": "echo \"Open http://localhost:3000/demo\" && NEXT_PUBLIC_DEMO_MODE=1 turbo dev --filter=@traibox/web",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "db:migrate": "tsx packages/db/src/migrate.ts",
    "db:reset": "tsx packages/db/src/reset.ts"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "turbo": "^2.3.0",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
