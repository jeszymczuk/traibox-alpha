# ---- Core ----
NODE_ENV=development

# Postgres (local dev via docker-compose)
DATABASE_URL=postgres://postgres:postgres@localhost:54321/traibox

# Optional: Set by API per request (RLS helper)
# APP_CURRENT_ORG is NOT a secret; API sets this via SET LOCAL app.current_org.

# ---- Supabase (prod/staging) ----
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# ---- API ----
API_PORT=3001
API_BASE_URL=http://localhost:3001
WEB_BASE_URL=http://localhost:3000
# Optional: restrict CORS to your web origin(s) (comma-separated).
# Example: CORS_ORIGIN=http://localhost:3000,https://<your-vercel-domain>
CORS_ORIGIN=http://localhost:3000

# ---- Web (Next.js) ----
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Dev-only fallback auth token (only used when Supabase Auth isn't configured)
NEXT_PUBLIC_AUTH_TOKEN=dev

# Deployment profile (policy-as-data)
# Examples:
#   packages/profiles/profiles/dev.yaml
#   packages/profiles/profiles/iberia-pilot.yaml
#   packages/profiles/profiles/eu-pilot.yaml
DEPLOYMENT_PROFILE_PATH=packages/profiles/profiles/dev.yaml

# Auth mode: "supabase" (default) or "dev"
AUTH_MODE=dev
DEV_USER_ID=00000000-0000-0000-0000-0000000000aa

# ---- Partner auth ----
PARTNER_JWT_SECRET=change-me

# Optional: protect admin bootstrap endpoints (recommended outside dev)
ADMIN_BOOTSTRAP_SECRET=

# ---- Compliance (ComplyAdvantage) ----
COMPLYADVANTAGE_API_KEY=
COMPLYADVANTAGE_BASE_URL=https://api.complyadvantage.com

# ---- KYB/KYC (Sumsub) ----
SUMSUB_APP_TOKEN=
SUMSUB_SECRET_KEY=
SUMSUB_BASE_URL=https://api.sumsub.com

# ---- Payments (TrueLayer) ----
TRUELAYER_CLIENT_ID=
TRUELAYER_CLIENT_SECRET=
TRUELAYER_BASE_URL=https://api.truelayer.com
TRUELAYER_AUTH_BASE_URL=https://auth.truelayer.com
TRUELAYER_WEBHOOK_SECRET=

# Encrypt stored bank tokens (recommended for any non-local environment)
TOKENS_ENCRYPTION_KEY=change-me

# Optional: bank data sync / reconciliation loop (worker)
# BANK_SYNC_INTERVAL_MS=600000
# BANK_SYNC_LOOKBACK_DAYS=7

# ---- Ledger anchoring (XDC / EVM) ----
EVM_RPC_URL=
EVM_ANCHOR_REGISTRY_ADDRESS=
EVM_ANCHOR_WALLET_PRIVATE_KEY=
EVM_CONFIRMATIONS=3
EVM_CHAIN_ID=50

# Optional: Ed25519 manifest signature (PEM)
LEDGER_MANIFEST_SIGNING_PRIVATE_KEY=
LEDGER_MANIFEST_SIGNING_PUBLIC_KEY=
